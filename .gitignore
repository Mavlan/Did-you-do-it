# Ignore files generated by Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates

# Ignore binaries
*.dll
*.exe

# Ignore the compiled addon
/YourAddonName/Release/
/YourAddonName/Debug/

# Ignore logs
*.log

# Ignore settings
SavedVariables/*.lua

# Ignore local files
*.local

# Ignore other temporary files
*.tmp
*.bak
*.swp
